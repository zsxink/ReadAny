---
import { defaultLang, useTranslations } from "../i18n/utils";

const lang = defaultLang;
const t = useTranslations(lang);
---

<Layout title="ReadAny - AI-Powered E-Book Reader">
  <Header lang={lang} t={t} />
  <main>
    <Hero t={t} />
    <Features t={t} />
    <Download t={t} />
    <Community t={t} />
  </main>
  <Footer t={t} />
</Layout>
