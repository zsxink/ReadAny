---
import { languages, defaultLang } from '../i18n/ui'

interface Props {
  lang?: keyof typeof languages
  t: (key: string) => string
}

const { lang = defaultLang, t } = Astro.props
const basePath = Astro.site?.pathname || '/'
const homeHref = lang === 'en' ? basePath : `${basePath}${lang}/`

const supportHref = lang === 'en'
  ? '/ReadAny/support/'
  : `/ReadAny/${lang}/support/`

const navItems = [
  { href: '#features', label: t('nav.features') },
  { href: '#download', label: t('nav.download') },
  { href: '#community', label: t('nav.community') },
  { href: supportHref, label: t('nav.support') },
]
---

<!-- Vercel-style: Clean, minimal header -->
<header class="fixed top-0 left-0 right-0 z-50 border-b border-border/50 bg-background/80 backdrop-blur-sm">
  <nav class="mx-auto flex h-14 max-w-5xl items-center justify-between px-6">
    <a href={homeHref} class="flex items-center gap-2">
      <img src={`/ReadAny/logo.svg`} alt="ReadAny" class="h-5 w-5" />
      <span class="font-medium">ReadAny</span>
    </a>
    
    <div class="flex items-center gap-6">
      {navItems.map((item) => (
        <a 
          href={item.href} 
          class="text-sm text-muted-foreground transition-colors hover:text-foreground hidden sm:block"
        >
          {item.label}
        </a>
      ))}
      
      <div class="flex items-center gap-2">
        {Object.entries(languages).map(([code, name]) => (
          <a
            href={code === 'en' ? '/ReadAny/' : `/ReadAny/${code}/`}
            class={`text-sm transition-colors ${
              lang === code
                ? 'text-foreground'
                : 'text-muted-foreground hover:text-foreground'
            }`}
          >
            {name}
          </a>
        ))}
      </div>
    </div>
  </nav>
</header>
