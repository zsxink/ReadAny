---
interface Props {
  t: (key: string) => string;
}

const { t } = Astro.props;

const useCases = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>`,
    title: t("useCases.research.title"),
    description: t("useCases.research.desc"),
    features: [t("useCases.research.f1"), t("useCases.research.f2"), t("useCases.research.f3")]
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" /></svg>`,
    title: t("useCases.language.title"),
    description: t("useCases.language.desc"),
    features: [t("useCases.language.f1"), t("useCases.language.f2"), t("useCases.language.f3")]
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>`,
    title: t("useCases.professional.title"),
    description: t("useCases.professional.desc"),
    features: [t("useCases.professional.f1"), t("useCases.professional.f2"), t("useCases.professional.f3")]
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>`,
    title: t("useCases.bookClub.title"),
    description: t("useCases.bookClub.desc"),
    features: [t("useCases.bookClub.f1"), t("useCases.bookClub.f2"), t("useCases.bookClub.f3")]
  }
];
---

<section class="py-32 bg-muted/30">
  <div class="mx-auto max-w-5xl px-6">
    <div class="max-w-2xl mb-16">
      <h2 class="text-3xl font-semibold tracking-tight">
        {t("useCases.title")}
      </h2>
      <p class="mt-4 text-muted-foreground">
        {t("useCases.subtitle")}
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-2">
      {useCases.map((useCase) => (
        <div class="group rounded-xl border border-border/50 bg-background p-6 transition-all hover:border-foreground/30 hover:shadow-lg">
          <div class="flex items-start gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
              <Fragment set:html={useCase.icon} />
            </div>
            
            <div class="flex-1">
              <h3 class="text-lg font-semibold mb-2">
                {useCase.title}
              </h3>
              
              <p class="text-sm text-muted-foreground leading-relaxed mb-4">
                {useCase.description}
              </p>

              <div class="flex flex-wrap gap-2">
                {useCase.features.map((feature) => (
                  <span class="inline-flex items-center rounded-full border border-border/50 bg-muted/50 px-3 py-1 text-xs font-medium">
                    {feature}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
