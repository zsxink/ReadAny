---

<section class="py-24 border-t border-border/50">
  <div class="mx-auto max-w-5xl px-6">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <h2 class="text-3xl font-semibold tracking-tight">
        {t("techStack.title")}
      </h2>
      <p class="mt-4 text-muted-foreground">
        {t("techStack.subtitle")}
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
      {techStack.map((tech) => (
        <div class="group flex flex-col items-center text-center p-4 rounded-lg transition-colors hover:bg-muted/50">
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-muted text-foreground mb-3 transition-colors group-hover:bg-primary/10 group-hover:text-primary">
            <Fragment set:html={tech.icon} />
          </div>
          <h3 class="text-sm font-semibold mb-1">
            {tech.name}
          </h3>
          <p class="text-xs text-muted-foreground">
            {tech.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
