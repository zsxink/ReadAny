{
  "cli": {
    "version": ">= 14.1.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "20.18.0"
    },
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "node": "20.18.0",
      "env": {
        "EXPO_NO_METRO_WORKSPACE_ROOT": "1"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "node": "20.18.0",
      "env": {
        "EXPO_NO_METRO_WORKSPACE_ROOT": "1"
      }
    }
  }
}
